.pio/
dist/

# User-local read/write working dirs — never commit user .bin dumps,
# log files, or anything they drop in here. The dist zip ships a
# minimal reads/ and writes/ scaffold with READMEs only; beyond that
# these directories are local to each user and must stay out of git.
reads/
writes/
reads/**
writes/**

__pycache__/
*.pyc
*.exe
.vscode/

# Internal / private docs
CLAUDE.md
T87-Calibration-Comparison.html
T87-Calibration-Comparison.rtf

# Captures and logs (not for public repo)
*.csv
*.log
*.js

# Kernel binaries — never commit proprietary third-party kernel bytes
src/*_private.h
kernels/

# Cernels — track source + shippable kernel.bin, ignore build artifacts
Cernels/**/*.o
Cernels/**/*.elf
Cernels/**/*.map
Cernels/**/*.lst

# Private kernel library — never committed. Users drop their own
# kernel binaries + meta.json into Cernels/private/<folder>/.
Cernels/private/**
!Cernels/private/.gitkeep
!Cernels/private/meta.json.template

# Extracted kernel dumps — tools/extract_*.py defaults target here.
# Users move/rename into Cernels/private/ once verified.
Cernels/extracted/**
!Cernels/extracted/.gitkeep

# Auto-generated kernel header dir (one .h per kernel bin, regenerated
# every build by tools/build_kernel_registry.py).
src/kernels_generated/
src/kernels_private.h
src/kernels_public.h

# Locally-extracted kernel headers — keep out of public commits.
src/kernel_*_extracted*.h

# Strays / local dev artifacts
COM38
uf2conv.py
tools/efi_check_license_sequence.txt
build_pyinstaller/
